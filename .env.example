# Copy to .env for local dev. .env is gitignored; never commit real secrets.
# The Postgres container reads these; migrations and tests read the *_DATABASE_URL pair.

POSTGRES_USER=mailengine
POSTGRES_PASSWORD=change_me
POSTGRES_DB=mailengine
POSTGRES_PORT=5433

# Read-only role (created at cluster init; SELECT-only, granted by migration 0002).
READONLY_USER=mailengine_ro
READONLY_PASSWORD=change_me_ro

# Owner connection: the only write path. Migrations run as this role.
OWNER_DATABASE_URL=postgresql://mailengine:change_me@localhost:5433/mailengine

# Read-only connection: the analysis bypass. Cannot write.
READONLY_DATABASE_URL=postgresql://mailengine_ro:change_me_ro@localhost:5433/mailengine

# Lob (print seam — docs/decisions.md). Test key = test_..., live = live_...
LOB_API_KEY=
LOB_WEBHOOK_SECRET=
LOB_COST_CENTS=87
LOB_FROM_NAME=
LOB_FROM_LINE1=
LOB_FROM_CITY=
LOB_FROM_STATE=
LOB_FROM_ZIP=

# PostHog response feed (FR-5, web response: ?r= -> page.visit / cta_click / signup).
# ⚠️ This is a PERSONAL API key (phx_...) with query:read scope — NOT the landing page's
# project key (the phc_... in landing-pages/shared/nmc-config.js), which can only WRITE
# events from the browser and cannot read them back. Create at:
#   PostHog -> Settings -> Personal API keys -> scope: query:read
# POSTHOG_PROJECT_ID is the NUMBER in the PostHog URL (app.posthog.com/project/<id>),
# not the phc_ key. Host is not configurable here: the feed queries us.posthog.com
# (the query API), which is a different host from us.i.posthog.com (ingestion).
# Left empty = the nightly skips this feed and prints that it skipped it.
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
